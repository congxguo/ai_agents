    {
      "id": "2R5EsAG1ZicWIhpuZREY7",
      "type": "text",
      "x": 64.06076417413738,
      "y": 2022.4748876546278,
      "width": 853.3436889648438,
      "height": 900,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dashed",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0H",
