      "version": 292,
      "versionNonce": 1771752438,
      "isDeleted": false,
      "boundElements": [
        {
          "type": "text",
          "id": "RjjIBTKHvmprxZCJaSBR5"
        },
        {
          "id": "dcgZsbetwdEWQEqqpetZp",
